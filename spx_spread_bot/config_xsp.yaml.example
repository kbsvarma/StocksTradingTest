# XSP Paper/Live bot configuration
# Copy this file to config_xsp.yaml and adjust values for your environment.

capital: 200000           # Notional capital for position sizing
max_contracts: 1
spread_width: 25
bwb_narrow_wing_width: 25
bwb_wide_wing_width: 50
condor_wing_width: 25
iron_fly_wing_width: 25
min_credit: 0.50
target_credit: 2.00
stop_multiplier: 2.0
profit_target_pct: 0.50
otm_pct_low_vix: 0.018
otm_pct_high_vix: 0.025
vix_min: 0
vix_max: 30

entry_start: "09:45"
entry_end: "10:15"
eod_check: "15:45"
friday_forced_close: "15:30"
timezone: "America/New_York"
# Scale the SPX 50-point expiry safety gate by 1/10 for XSP.
expiry_safety_distance_points: 5.0

paper_trading: true
live_mode_enabled: false
host: "127.0.0.1"
port: 4002
client_id: 41           # Use a different client_id from the SPX bot
market_data_type: 1

underlying_symbol: "XSP"
underlying_exchange: "CBOE"
option_exchange: "SMART"
combo_exchange: "SMART"
preferred_trading_class: "XSP"
currency: "USD"

max_margin_usage_pct: 0.50
min_available_margin: 5000

run_days: [0, 1, 2, 3, 4]
dte_candidates: [0, 2]
trade_once_per_day: true
enabled_strategies: ["BULL_PUT_SPREAD"]
strategy_priority: ["BULL_PUT_SPREAD"]

max_retries: 3
retry_price_step: 0.05
retry_wait_seconds: 120
fill_timeout_seconds: 300
protection_deadline_seconds: 10

monitor_interval_seconds: 1
tick_log_interval_seconds: 0.25

auto_place_on_signal: true
one_click_confirm: false

macro_provider: "hybrid"
macro_fail_open: false
macro_api_key: ""              # Set your macro API key here if using a paid provider
manual_macro_dates_csv: "data/manual_macro_dates.csv"
macro_refresh_hour_et: 6

data_dir: "data/xsp"
logs_dir: "logs/xsp"
state_file: "data/xsp/runtime_state.json"
status_file: "data/xsp/status.json"
signal_events_file: "logs/xsp/signal_events.jsonl"
order_events_file: "logs/xsp/order_events.jsonl"
tick_events_file: "logs/xsp/tick_events.jsonl"
daily_summary_file: "logs/xsp/daily_summary.log"
trade_csv_file: "data/xsp/trades.csv"
