# ── Virtual environment ──────────────────────────────────────
.venv/
venv/
env/

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Sensitive config (copy config.yaml.example → config.yaml)
config.yaml
config_xsp.yaml

