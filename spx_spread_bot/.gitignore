deploy/lightsail/enter_credentials_linux.sh

# ── Runtime data & logs ──────────────────────────────────────
data/*
!data/.gitkeep
!data/manual_macro_dates.csv
logs/*
!logs/.gitkeep

# ── Backtests output ─────────────────────────────────────────
backtests/

