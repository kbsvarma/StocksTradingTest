# ── Virtual environment ──────────────────────────────────────
.venv/
venv/
env/

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Sensitive config (copy config.yaml.example → config.yaml)
config.yaml
config_xsp.yaml

# ── IBKR credentials script (prompts for / writes live creds)
deploy/lightsail/enter_credentials_linux.sh

# ── Runtime data & logs ──────────────────────────────────────
data/*
!data/.gitkeep
!data/manual_macro_dates.csv
logs/*
!logs/.gitkeep

# ── Backtests output ─────────────────────────────────────────
# Raw Databento cache is 645MB of binary files — keep local only.
# Re-downloadable by running the backtest script with DATABENTO_API_KEY set.
backtests/ten_year/raw_dbn_cache/
# PID / process-management files are ephemeral
backtests/ten_year/*.pid
backtests/ten_year/extend_queue.*
backtests/ten_year/run.pid
backtests/stop_*/*.pid
backtests/stop_*/run.out
backtests/stop_*/backtest.log

# ── OS / editor noise ────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Certificates / keys ──────────────────────────────────────
*.pem
*.key
*.crt
